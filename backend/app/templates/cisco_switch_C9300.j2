! SYSTEM
version 17.3
hostname {{ hostname }}

! AAA
aaa new-model
aaa authentication login default group tacacs+ local

! SECURITY
no ip domain-lookup
login block-for 120 attempts 5 within 60

! DNS
ip domain-name {{ domain_name }}

! NTP
ntp server {{ ntp_servers }}

! SNMP
snmp-server community {{ snmp_group }} RO

! LOGGING
logging host {{ syslog_servers }}

! INTERFACES
interface GigabitEthernet1/0/1

! HIGH AVAILABILITY
interface GigabitEthernet1/0/2
 standby 1 ip {{ ip_address }}